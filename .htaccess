# Cabeceras de seguridad para hosts Apache.
# (En Netlify/Cloudflare Pages usa el archivo _headers; este archivo es inofensivo allí.)
<IfModule mod_headers.c>
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://images.unsplash.com; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), usb=(), browsing-topics=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Cross-Origin-Opener-Policy "same-origin"
</IfModule>

# Evita servir archivos sensibles si por error llegan al hosting
<FilesMatch "(^\.|\.(env|gitignore|md|log)$)">
  Require all denied
</FilesMatch>
